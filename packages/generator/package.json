{
  "name": "@shrkcrft/generator",
  "version": "0.1.0-alpha.8",
  "description": "SharkCraft plan-first generator: GenerationPlan, FileChange, dry-run, safe writes.",
  "license": "MIT",
  "author": "SharkCraft contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrkcrft/sharkcraft.git",
    "directory": "packages/generator"
  },
  "homepage": "https://github.com/shrkcrft/sharkcraft",
  "bugs": {
    "url": "https://github.com/shrkcrft/sharkcraft/issues"
  },
  "keywords": [
    "sharkcraft",
    "generator",
    "codegen",
    "dry-run"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@shrkcrft/core": "workspace:*",
    "@shrkcrft/templates": "workspace:*",
    "@shrkcrft/rules": "workspace:*",
    "@shrkcrft/paths": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
