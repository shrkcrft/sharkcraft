{
  "name": "@shrkcrft/context",
  "version": "0.1.0-alpha.13",
  "description": "SharkCraft AI context builder: token-budgeted relevance retrieval for tasks.",
  "license": "MIT",
  "author": "SharkCraft contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrkcrft/sharkcraft.git",
    "directory": "packages/context"
  },
  "homepage": "https://github.com/shrkcrft/sharkcraft",
  "bugs": {
    "url": "https://github.com/shrkcrft/sharkcraft/issues"
  },
  "keywords": [
    "sharkcraft",
    "context",
    "ai",
    "token-budget",
    "mcp"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@shrkcrft/core": "workspace:*",
    "@shrkcrft/knowledge": "workspace:*",
    "@shrkcrft/rules": "workspace:*",
    "@shrkcrft/paths": "workspace:*",
    "@shrkcrft/templates": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
