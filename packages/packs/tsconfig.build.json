{
  "extends": "../../tsconfig.publish.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@shrkcrft/core": [
        "../core/dist/index.d.ts"
      ],
      "@shrkcrft/plugin-api": [
        "../plugin-api/dist/index.d.ts"
      ]
    },
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__/**/*"
  ]
}
