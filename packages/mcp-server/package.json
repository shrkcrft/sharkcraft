{
  "name": "@shrkcrft/mcp-server",
  "version": "0.1.0-alpha.18",
  "description": "SharkCraft MCP server: 25 tools over @modelcontextprotocol/sdk's stdio transport.",
  "license": "MIT",
  "author": "SharkCraft contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrkcrft/sharkcraft.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/shrkcrft/sharkcraft",
  "bugs": {
    "url": "https://github.com/shrkcrft/sharkcraft/issues"
  },
  "keywords": [
    "sharkcraft",
    "mcp",
    "modelcontextprotocol",
    "ai-agent",
    "claude"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@shrkcrft/core": "workspace:*",
    "@shrkcrft/compress": "workspace:*",
    "@shrkcrft/config": "workspace:*",
    "@shrkcrft/workspace": "workspace:*",
    "@shrkcrft/knowledge": "workspace:*",
    "@shrkcrft/context": "workspace:*",
    "@shrkcrft/rules": "workspace:*",
    "@shrkcrft/paths": "workspace:*",
    "@shrkcrft/templates": "workspace:*",
    "@shrkcrft/pipelines": "workspace:*",
    "@shrkcrft/presets": "workspace:*",
    "@shrkcrft/boundaries": "workspace:*",
    "@shrkcrft/graph": "workspace:*",
    "@shrkcrft/rule-graph": "workspace:*",
    "@shrkcrft/structural-search": "workspace:*",
    "@shrkcrft/impact-engine": "workspace:*",
    "@shrkcrft/context-planner": "workspace:*",
    "@shrkcrft/architecture-guard": "workspace:*",
    "@shrkcrft/framework-scanners": "workspace:*",
    "@shrkcrft/api-surface-diff": "workspace:*",
    "@shrkcrft/quality-gates": "workspace:*",
    "@shrkcrft/migrate": "workspace:*",
    "@shrkcrft/packs": "workspace:*",
    "@shrkcrft/generator": "workspace:*",
    "@shrkcrft/inspector": "workspace:*",
    "@shrkcrft/embeddings": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
