{
  "extends": "../../tsconfig.publish.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@shrkcrft/core": [
        "../core/dist/index.d.ts"
      ],
      "@shrkcrft/boundaries": [
        "../boundaries/dist/index.d.ts"
      ],
      "@shrkcrft/inspector": [
        "../inspector/dist/index.d.ts"
      ],
      "@shrkcrft/shared": [
        "../shared/dist/index.d.ts"
      ]
    },
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__/**/*"
  ]
}
