{
  "name": "@shrkcrft/graph",
  "version": "0.1.0-alpha.24",
  "description": "SharkCraft code intelligence graph: files, symbols, packages, imports and exports. Persistent JSONL store; on-disk index queried by every other code-intelligence package.",
  "license": "MIT",
  "author": "SharkCraft contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharkcraft/sharkcraft.git",
    "directory": "packages/graph"
  },
  "homepage": "https://github.com/sharkcraft/sharkcraft",
  "bugs": {
    "url": "https://github.com/sharkcraft/sharkcraft/issues"
  },
  "keywords": [
    "sharkcraft",
    "graph",
    "code-intelligence",
    "import-graph",
    "symbol-graph",
    "monorepo"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@shrkcrft/core": "workspace:*",
    "@shrkcrft/boundaries": "workspace:*",
    "@shrkcrft/inspector": "workspace:*",
    "@shrkcrft/shared": "workspace:*",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
