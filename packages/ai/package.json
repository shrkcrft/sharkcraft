{
  "name": "@shrkcrft/ai",
  "version": "0.1.0-alpha.21",
  "description": "SharkCraft local LLM provider abstraction: Ollama (HTTP) + llama.cpp (in-process) + multi-pass enhancement pipeline.",
  "license": "MIT",
  "author": "SharkCraft contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrkcrft/sharkcraft.git",
    "directory": "packages/ai"
  },
  "homepage": "https://github.com/shrkcrft/sharkcraft",
  "bugs": {
    "url": "https://github.com/shrkcrft/sharkcraft/issues"
  },
  "keywords": [
    "sharkcraft",
    "ai",
    "claude",
    "anthropic"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@shrkcrft/core": "workspace:*",
    "@shrkcrft/context": "workspace:*",
    "node-llama-cpp": "^3.16.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
