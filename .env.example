# SharkCraft AI-agent workflow configuration.
# Copy to .env (gitignored) or set as repo Actions variables.
#
# Comma-separated GitHub logins.
# - SHARKCRAFT_AI_ALLOWED_ACTORS: who can open [AI]-titled issues that
#   the workflow will plan against.
# - SHARKCRAFT_AI_MAINTAINERS:    who can apply ai:plan / ai:implement
#   labels to route the agent into plan/implement mode.
#
# Empty default = deny everyone (the gate ignores every event).
SHARKCRAFT_AI_ALLOWED_ACTORS=
SHARKCRAFT_AI_MAINTAINERS=

# ─────────────────────────────────────────────────────────────
# `shrk smart-context` — LLM provider configuration
# ─────────────────────────────────────────────────────────────
# SharkCraft only uses **local** LLMs: Ollama (HTTP) and llama.cpp
# (in-process, via node-llama-cpp). No hosted-API keys, no surprise
# network calls.
#
# AI_PROVIDER selects the default provider when no `--provider` flag
# is passed. Accepted values: ollama | llamacpp | auto.
# `auto` (the default) walks the local-first chain: llamacpp → ollama.
#
# When no LLM is reachable, every shrk command keeps working — the
# deterministic engine is the source of truth, the LLM only refines
# its output. Leave everything blank for an entirely offline,
# zero-LLM run.
AI_PROVIDER=

# ─── Ollama (local HTTP — https://ollama.com) ────────────────
# Two ways to configure the endpoint:
#
#   1) Full URL in OLLAMA_HOST (OLLAMA_PORT is ignored):
#        OLLAMA_HOST=http://my-box:11434
#
#   2) Bare host + port (assembled as http://<host>:<port>):
#        OLLAMA_HOST=my-box
#        OLLAMA_PORT=11434
#
# Leave both blank to default to http://localhost:11434.
#
# OLLAMA_MODEL is the default model. Override per-call with
# `shrk smart-context "<task>" --provider ollama --model <id>`.
OLLAMA_HOST=
OLLAMA_PORT=
OLLAMA_MODEL=

# ─── llama.cpp (in-process — no HTTP, no daemon) ─────────────
# Recommended model for code tasks: qwen2.5-coder-3b (Q4_K_M gguf, ~2 GB).
# LLAMACPP_MODEL_PATH must point to a .gguf file readable by llama.cpp.
# LLAMACPP_CONTEXT_SIZE defaults to 8192.
# LLAMACPP_GPU: auto | metal | cuda | off
LLAMACPP_MODEL_PATH=
LLAMACPP_CONTEXT_SIZE=
LLAMACPP_GPU=

# ─── Semantic embedding index (Xenova/bge-base-en-v1.5) ──────
# transformers.js runs ONNX on CPU only in Node (no Metal/WebGPU
# outside the browser). On Apple Silicon CPU, `q8` (int8 quantized)
# is ~2-3× faster than fp32 with negligible retrieval-quality loss
# and is the default. Override only if you need maximum precision
# (e.g. for a regression study against fp32).
#
# Accepted: fp32 | fp16 | q8 (default) | int8 | uint8 | q4 | q4f16 | bnb4
SHRK_EMBEDDINGS_DTYPE=

# ─── Multi-pass enhancement pipeline ─────────────────────────
# When an LLM is ready, `shrk smart-context` (and other enrichable
# commands) run a multi-pass refinement pipeline: draft → critique →
# refine → polish. Set SHRK_ENHANCE_PASSES to cap the number of LLM
# round-trips (default 3). Set SHRK_ENHANCE=off to disable the
# pipeline globally (single-shot LLM call only). The deterministic
# fallback is unaffected.
SHRK_ENHANCE=
SHRK_ENHANCE_PASSES=
