{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://shrkcrft.dev/schemas/adoption-merge-preview.json",
  "title": "SharkCraft Adoption Merge Preview",
  "type": "object",
  "required": [
    "schema",
    "targets",
    "safeBlocks",
    "manualReview",
    "lowConfidenceSkipped"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.adoption-merge-preview/v1"
    },
    "targets": {
      "type": "array"
    },
    "safeBlocks": {
      "type": "array"
    },
    "manualReview": {
      "type": "array"
    },
    "lowConfidenceSkipped": {
      "type": "array"
    },
    "existingCoverage": {
      "type": "array"
    },
    "conflicts": {
      "type": "array"
    },
    "patchFreshness": {
      "type": "object"
    },
    "recommendedCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
