{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://shrkcrft.dev/schemas/feature-bundle.json",
  "title": "SharkCraft Feature Workflow Bundle",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "id",
    "task",
    "status"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.feature-bundle/v1"
    },
    "id": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "plans": {
      "type": "array"
    },
    "planGroups": {
      "type": "array"
    },
    "dependencies": {
      "type": "array"
    },
    "validations": {
      "type": "array"
    },
    "affectedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affectedAreas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "type": "string"
    },
    "nextAction": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
