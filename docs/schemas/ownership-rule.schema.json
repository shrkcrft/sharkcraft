{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "urn:sharkcraft:schemas:ownership-rule",
  "title": "SharkCraft Ownership Rule",
  "type": "object",
  "required": [
    "id",
    "title",
    "paths",
    "owners"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredReview": {
      "type": "boolean"
    }
  }
}
