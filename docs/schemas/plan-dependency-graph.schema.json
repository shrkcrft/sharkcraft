{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "urn:sharkcraft:schemas:plan-dependency-graph",
  "title": "SharkCraft Plan Dependency Graph",
  "type": "object",
  "required": [
    "schema",
    "bundleId",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.plan-dependency-graph/v1"
    },
    "bundleId": {
      "type": "string"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    },
    "order": {
      "type": "array"
    }
  }
}
