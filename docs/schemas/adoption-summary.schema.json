{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://shrkcrft.dev/schemas/adoption-summary.json",
  "title": "SharkCraft Adoption Summary",
  "type": "object",
  "required": [
    "confidence",
    "summary",
    "items",
    "format",
    "targets"
  ],
  "properties": {
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "items": {
      "type": "array"
    },
    "format": {
      "enum": [
        "pseudo",
        "unified"
      ]
    },
    "targets": {
      "type": "array"
    }
  }
}
