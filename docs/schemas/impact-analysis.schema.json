{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "urn:sharkcraft:schemas:impact-analysis",
  "title": "SharkCraft Impact Analysis",
  "type": "object",
  "required": [
    "schema",
    "task"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.impact-analysis/v1"
    },
    "task": {
      "type": "string"
    },
    "risk": {
      "type": "string"
    },
    "affectedFiles": {
      "type": "array"
    },
    "affectedAreas": {
      "type": "array"
    }
  }
}
