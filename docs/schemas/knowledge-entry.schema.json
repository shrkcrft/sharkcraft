{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "urn:sharkcraft:schemas:knowledge-entry",
  "title": "SharkCraft Knowledge Entry",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "priority",
    "content"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([.-][a-z0-9]+)*$"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "priority": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "appliesWhen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "content": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "actionHints": {
      "$ref": "action-hints.json"
    }
  }
}
