{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://shrkcrft.dev/schemas/execution-graph.json",
  "title": "SharkCraft Task Execution Graph",
  "type": "object",
  "required": [
    "schema",
    "task",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.execution-graph/v1"
    },
    "task": {
      "type": "string"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    }
  }
}
