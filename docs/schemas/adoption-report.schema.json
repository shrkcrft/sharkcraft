{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "urn:sharkcraft:schemas:adoption-report",
  "title": "SharkCraft Adoption Report",
  "type": "object",
  "required": [
    "schema"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.adoption-report/v1"
    },
    "summary": {
      "type": "object"
    },
    "categories": {
      "type": "object"
    },
    "targets": {
      "type": "array"
    },
    "patchPath": {
      "type": "string"
    },
    "safeToAdopt": {
      "type": "array"
    },
    "manualReview": {
      "type": "array"
    },
    "conflicts": {
      "type": "array"
    },
    "lowConfidence": {
      "type": "array"
    },
    "recommendedCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safetyModel": {
      "type": "object"
    }
  }
}
