{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://shrkcrft.dev/schemas/plan-simulation.json",
  "title": "SharkCraft Plan Simulation Report",
  "type": "object",
  "required": [
    "schema",
    "source",
    "planSchema",
    "applyReadiness",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "sharkcraft.plan-simulation/v1"
    },
    "source": {
      "type": "string"
    },
    "planSchema": {
      "type": "string"
    },
    "applyReadiness": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "files": {
      "type": "array"
    },
    "potentialBoundaryConcerns": {
      "type": "array"
    },
    "planIntroducedBoundaryConcerns": {
      "type": "array"
    }
  }
}
