{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun", "node"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@shrkcrft/core": ["./packages/core/src/index.ts"],
      "@shrkcrft/config": ["./packages/config/src/index.ts"],
      "@shrkcrft/knowledge": ["./packages/knowledge/src/index.ts"],
      "@shrkcrft/context": ["./packages/context/src/index.ts"],
      "@shrkcrft/workspace": ["./packages/workspace/src/index.ts"],
      "@shrkcrft/rules": ["./packages/rules/src/index.ts"],
      "@shrkcrft/paths": ["./packages/paths/src/index.ts"],
      "@shrkcrft/templates": ["./packages/templates/src/index.ts"],
      "@shrkcrft/generator": ["./packages/generator/src/index.ts"],
      "@shrkcrft/inspector": ["./packages/inspector/src/index.ts"],
      "@shrkcrft/ai": ["./packages/ai/src/index.ts"],
      "@shrkcrft/embeddings": ["./packages/embeddings/src/index.ts"],
      "@shrkcrft/pipelines": ["./packages/pipelines/src/index.ts"],
      "@shrkcrft/packs": ["./packages/packs/src/index.ts"],
      "@shrkcrft/importer": ["./packages/importer/src/index.ts"],
      "@shrkcrft/presets": ["./packages/presets/src/index.ts"],
      "@shrkcrft/boundaries": ["./packages/boundaries/src/index.ts"],
      "@shrkcrft/graph": ["./packages/graph/src/index.ts"],
      "@shrkcrft/rule-graph": ["./packages/rule-graph/src/index.ts"],
      "@shrkcrft/structural-search": ["./packages/structural-search/src/index.ts"],
      "@shrkcrft/impact-engine": ["./packages/impact-engine/src/index.ts"],
      "@shrkcrft/context-planner": ["./packages/context-planner/src/index.ts"],
      "@shrkcrft/architecture-guard": ["./packages/architecture-guard/src/index.ts"],
      "@shrkcrft/framework-scanners": ["./packages/framework-scanners/src/index.ts"],
      "@shrkcrft/api-surface-diff": ["./packages/api-surface-diff/src/index.ts"],
      "@shrkcrft/quality-gates": ["./packages/quality-gates/src/index.ts"],
      "@shrkcrft/migrate": ["./packages/migrate/src/index.ts"],
      "@shrkcrft/plugin-api": ["./packages/plugin-api/src/index.ts"],
      "@shrkcrft/dashboard-api": ["./packages/dashboard-api/src/index.ts"],
      "@shrkcrft/shared": ["./packages/shared/src/index.ts"],
      "@shrkcrft/cli": ["./packages/cli/src/index.ts"],
      "@shrkcrft/mcp-server": ["./packages/mcp-server/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "examples/*/sharkcraft/**/*.ts",
    "tools/**/*.ts"
  ],
  "exclude": ["**/node_modules", "**/dist", "packages/dashboard/**"]
}
